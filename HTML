<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SULEMAN CLOUD V9.0</title>
    <style>
        body, html { margin:0; padding:0; height:100%; overflow:hidden; background:#000; }
        iframe { width:100%; height:100%; border:none; }
        #sule_box { position:fixed; top:10px; right:10px; width:140px; background:rgba(10,20,40,0.9); border:2px solid #ffcc33; border-radius:15px; color:white; padding:10px; text-align:center; z-index:9999; font-family:sans-serif; box-shadow:0 0 15px #000; }
        .next { font-size:30px; font-weight:900; color:#ffcc33; margin:5px 0; }
        .data-text { font-size:10px; color:#00ff88; }
    </style>
</head>
<body>
    <div id="sule_box">
        <div style="font-size:9px; color:#888;">SULEMAN ENGINE</div>
        <div style="font-size:11px;">NEXT ADVICE</div>
        <div id="p_val" class="next">WAIT</div>
        <div class="data-text">📊 STORED: <span id="c_val">0</span></div>
    </div>
    <iframe id="game" src="https://www.sikkimok.com/#/register?invitationCode=78186312458"></iframe>

    <script>
        let history = JSON.parse(localStorage.getItem('sule_cloud_data')) || [];
        function update() {
            document.getElementById('c_val').innerText = history.length;
            // प्रेडिक्शन लॉजिक (Dragon Follow)
            let p = (history.length % 2 === 0) ? "BIG" : "SMALL";
            document.getElementById('p_val').innerText = p;
            document.getElementById('p_val').style.color = (p === "SMALL") ? "#fff176" : "#ffab40";
        }
        setInterval(update, 2000);
        update();
    </script>
</body>
</html>
